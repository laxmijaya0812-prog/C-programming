#include <stdio.h>
int sumEven(int start, int end);
int main() {
int start, end;
printf("Enter start of range: ");
scanf("%d", &start);
printf("Enter end of range: ");
scanf("%d", &end);
printf("Sum of even numbers between %d and %d = %d\n", start, end, sumEven(start, end));
return 0;
}
int sumEven(int start, int end) {
if (start > end)
return 0;
if (start % 2 == 0)
return start + sumEven(start + 1, end);
else
return sumEven(start + 1, end);
}
