#include <stdio.h>
int main() {
char str[200]="the quick brown fox jumps over the lazy dog";
int i, flag = 1;
int alpha[26];
for (i = 0; str[i] != '\0'; i++) {
if (str[i] >= 'a' && str[i] <= 'z')
alpha[str[i]-'a'] = 1;
}
for (i = 0; i < 26; i++) {
if (alpha[i] == 0)
flag = 0;
}
if (flag)
printf("It is a Pangram.\n");
else
printf("It is NOT a Pangram.\n");
return 0;
}
