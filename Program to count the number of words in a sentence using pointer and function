#include<stdio.h>
int countWords(char *sentence);
int main() {
char sentence[] = "Programming is fun and challenging AAA";
int no;
no=countWords(sentence);
printf("Number of words: %d\n",no);
return 0;
}
int countWords(char *sentence) {
int count = 1;
for (int i = 0; sentence[i] != '\0'; ++i) {
if (sentence[i] == ' ') {
count++;
}
}
return count;
}
