#include <stdio.h>
int main() {
int arr[100]={10,12,15,17,18,20};
int n=6, pos;
printf("Enter the position to delete ");
scanf("%d", &pos);
if (pos < 1 || pos > n) {
printf("Invalid position!
\n");

} else {
for (int i = pos
- 1; i < n
- 1; i++) {

arr[i] = arr[i + 1];
}
n--;
printf("Array after deletion:
\n");
for (int i = 0; i < n; i++) {
printf("%d ", arr[i]);
}
}
return 0;
}
