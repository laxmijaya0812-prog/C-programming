#include <stdio.h>
int main() {
char s1[50] = "SHREYA ";
char s2[50] = "KANIGASRI";
int i, j, k;
for (i = 0; s1[i] != '\0'; i++) {
for (j = 0; s2[j] != '\0'; j++) {
if (s1[i] == s2[j]) {
for (k = i; s1[k] != '\0'; k++)
s1[k] = s1[k + 1];
for (k = j; s2[k] != '\0'; k++)
s2[k] = s2[k + 1];
}
}
}
printf("String 1: %s\n", s1);
printf("String 2: %s\n", s2);
return 0;
}
