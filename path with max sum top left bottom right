#include <stdio.h>

int main() {
    int r, c, i, j;
    int a[10][10], dp[10][10];

    printf("Enter rows and columns: ");
    scanf("%d %d", &r, &c);

    printf("Enter matrix elements:\n");
    for(i = 0; i < r; i++)
        for(j = 0; j < c; j++)
            scanf("%d", &a[i][j]);

    dp[0][0] = a[0][0];

    // First row
    for(j = 1; j < c; j++)
        dp[0][j] = dp[0][j-1] + a[0][j];

    // First column
    for(i = 1; i < r; i++)
        dp[i][0] = dp[i-1][0] + a[i][0];

    // Remaining cells
    for(i = 1; i < r; i++) {
        for(j = 1; j < c; j++) {
            if(dp[i-1][j] > dp[i][j-1])
                dp[i][j] = dp[i-1][j] + a[i][j];
            else
                dp[i][j] = dp[i][j-1] + a[i][j];
        }
    }

    printf("Maximum Path Sum = %d", dp[r-1][c-1]);

    return 0;
}
