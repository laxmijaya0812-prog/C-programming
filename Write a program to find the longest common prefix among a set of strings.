#include <stdio.h>
#include <string.h>
int main() {
char str[3][20] = {"flower", "flow", "flight"};
char prefix[20];
int i, j;
// copy first string as initial prefix
strcpy(prefix, str[0]);
// compare prefix with remaining strings
for (i = 1; i < 3; i++) {
j = 0;
while (prefix[j] != '\0' && str[i][j] != '\0' &&
prefix[j] == str[i][j]) {
j++;
}
prefix[j] = '\0'; // shorten prefix
}
if (prefix[0] == '\0')
printf("No common prefix");
else
printf("Longest common prefix: %s", prefix);
return 0;
}
