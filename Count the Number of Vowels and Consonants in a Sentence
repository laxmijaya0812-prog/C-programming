#include <stdio.h>
void main() {
char sentence[20]="KRISHAMEENATCHI ";
int i, vowels = 0, consonants = 0;
char ch;
for (i = 0; sentence[i] != '\0'; i++) {
ch = sentence[i];
if (ch >= 'a' && ch <= 'z') {
if (ch == 'a' || ch == 'e' || ch == 'i' || ch == 'o' || ch == 'u')
vowels++;
else
consonants++;
}
}
printf("Number of vowels: %d\n", vowels);
printf("Number of consonants: %d\n", consonants);
}
